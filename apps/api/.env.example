# PostgreSQL / Supabase
DATABASE_URL=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=school-assets

# Auth
JWT_SECRET=
ROOT_ADMIN_EMAIL=  # Required: the Chronix Technology root platform admin email; server refuses to start if unset
NEXTAUTH_SECRET=
NEXTAUTH_URL=
APP_URL=
NEXT_PUBLIC_API_URL=

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=
HEALTH_CHECK_TOKEN=  # Optional: token required in X-Health-Token header to access /health

# Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@chronixedu.com

# SMS (Termii)
TERMII_API_KEY=
TERMII_SENDER_ID=ChronixEdu

# Payments (Paystack)
PAYSTACK_SECRET_KEY=

# Super Admin Platform (Phase 4)
SUPER_ADMIN_PASSWORD=          # Password for moses@chronixtech.com
SUPPORT_SESSION_MAX_DURATION_HOURS=0.5  # Default: 30 minutes; set in hours (0.5 = 30m)
PLATFORM_AUDIT_LOG_RETENTION_DAYS=365

# Dev-only seed endpoint secret (do NOT set in Railway production)
SEED_SECRET=                   # Generate with: openssl rand -hex 32
