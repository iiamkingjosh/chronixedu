{
  "name": "@chronixedu/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/templates','dist/templates',{recursive:true})\"",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "test": "jest --runInBand",
    "seed:superadmin": "ts-node src/scripts/seedSuperAdmin.ts",
    "migrate": "ts-node src/scripts/migrate.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.18",
    "@types/node": "^20.14.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.3.3"
  }
}
