{
  "name": "chronixedu",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace=@chronixedu/web run dev",
    "dev:api": "npm --workspace=@chronixedu/api run dev",
    "lint:web": "npm --workspace=@chronixedu/web run lint",
    "lint:api": "npm --workspace=@chronixedu/api run lint",
    "lint": "npm run lint:web && npm run lint:api",
    "test": "jest",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.25.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.4",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "typescript": "5.3.3"
  }
}
